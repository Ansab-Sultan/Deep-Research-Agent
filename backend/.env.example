APP_NAME="Open Deep Research Agent Backend"
API_PREFIX=/api
LOG_LEVEL=INFO

# Gemini Configuration
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_API_KEY=your_gemini_api_key_here

# Research Tools
TAVILY_API_KEY=your_tavily_api_key_here

# Embedding Configuration
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384
ENABLE_EMBEDDING_MODEL_LOADING=true
EMBEDDING_DEVICE=cpu
REQUIRE_EMBEDDING_MODEL_ON_STARTUP=true

# Database Configuration
REDIS_URL=redis://localhost:6379/0
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=deep_research
QDRANT_URL=http://localhost:6333

# Job & Performance Settings
JOB_TTL_SECONDS=86400
STREAM_POLL_INTERVAL_SECONDS=0.3
POLISH_MIN_RATIO=0.95

# Research Depth: Quick
DEPTH_QUICK_ITERATIONS=1
DEPTH_QUICK_QUERY_FANOUT=2
DEPTH_QUICK_TARGET_SECTIONS=4

# Research Depth: Standard
DEPTH_STANDARD_ITERATIONS=2
DEPTH_STANDARD_QUERY_FANOUT=3
DEPTH_STANDARD_TARGET_SECTIONS=8

# Research Depth: Deep
DEPTH_DEEP_ITERATIONS=3
DEPTH_DEEP_QUERY_FANOUT=4
DEPTH_DEEP_TARGET_SECTIONS=12
